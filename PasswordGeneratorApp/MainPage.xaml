<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PasswordGeneratorApp.MainPage">

    <ScrollView>
        <Border MaximumWidthRequest="600"
                MaximumHeightRequest="600">
            
            <Grid RowDefinitions="Auto, Auto, Auto">
                <!-- Контейнер с информацией о пароле -->
                <VerticalStackLayout Grid.Row="0"
                                     MinimumHeightRequest="80">
                    <!-- Текстовое поле для оценки надёжности пароля -->
                    <Label/>
                    <!-- Поле для: демонстрации, кнопки генерации и кнопки копирования пароля -->
                        <Border Margin="20, 20, 20, 20"
                                MinimumHeightRequest="50">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <!-- Для пароля -->
                            <Label Margin="10, 0"
                                   Text="{Binding GeneratedPassword}"
                                   Grid.Column="0"/>
                            <Button Command="{Binding GenerateCommand}"
                                    Text="Generate"
                                    FontSize="12"
                                    MaximumWidthRequest="80"
                                    Margin="0, 10"
                                    Grid.Column="1"/>
                            <Button Command="{Binding CopyCommand}"
                                    Text="Copy"
                                    FontSize="12"
                                    MaximumWidthRequest="80"
                                    Margin="10, 10"
                                    Grid.Column="2"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
                
                <!-- Контейнер для настройки длинны пароля -->
                <Grid Grid.Row="1"
                    ColumnDefinitions="Auto, Auto, *">
                    <Label Grid.Column="0"
                           Text="Длина пароля"
                           Margin="10, 0, 0, 0"
                           Style="{StaticResource SettingsLabel}"/>
                    <!-- Поле ввода длины пароля -->
                    <Entry Grid.Column="1"
                           FontSize="16"
                           WidthRequest="50"
                           HeightRequest="40"
                           Margin="10, 0, 0, 0"
                           Text="{Binding PasswordLengthText, Mode=TwoWay}"/>
                    <!-- Ползунок для выбора длины пароля -->
                    <Slider Grid.Column="2"
                            Minimum="4"
                            Maximum="64"
                            Margin="10, 0, 10, 0"
                            Value="{Binding PasswordLength, Mode=TwoWay}"/>
                </Grid>
                
                <!-- Контейнер для настройки флагов пароля -->
                <FlexLayout Grid.Row="2"
                            Direction="Row"
                            JustifyContent="SpaceBetween"
                            Wrap="Wrap"
                            Margin="20">
                    <HorizontalStackLayout
                        Style="{StaticResource SettingsItem}">
                        <CheckBox Command="{Binding ToCheckToggleButtonCommand}"
                                  CommandParameter="{Binding Text, Source={x:Reference UpperCaseLabel}}"/>
                        <Label x:Name="UpperCaseLabel"
                               Text="Верхний регистр"
                               Style="{StaticResource SettingsLabel}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout
                        Style="{StaticResource SettingsItem}">
                        <CheckBox Command="{Binding ToCheckToggleButtonCommand}"
                                  CommandParameter="{Binding Text, Source={x:Reference LowerCaseLabel}}"/>
                        <Label x:Name="LowerCaseLabel"
                               Text="Нижний регистр"
                               Style="{StaticResource SettingsLabel}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout
                        Style="{StaticResource SettingsItem}">
                        <CheckBox Command="{Binding ToCheckToggleButtonCommand}"
                                  CommandParameter="{Binding Text, Source={x:Reference NumbersLabel}}"/>
                        <Label x:Name="NumbersLabel"
                               Text="Цифры"
                               Style="{StaticResource SettingsLabel}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout
                        Style="{StaticResource SettingsItem}">
                        <CheckBox Command="{Binding ToCheckToggleButtonCommand}"
                                  CommandParameter="{Binding Text, Source={x:Reference SymbolsLabel}}"/>
                        <Label x:Name="SymbolsLabel"
                               Text="Символы"
                               Style="{StaticResource SettingsLabel}"/>
                    </HorizontalStackLayout>
                </FlexLayout>
            </Grid>
        </Border>
    </ScrollView>

</ContentPage>
